# Etsy Open API v3
# Format: keystring:shared_secret
ETSY_API_KEY=your_etsy_keystring:your_etsy_shared_secret
ETSY_ACCESS_TOKEN=your_etsy_oauth_access_token
ETSY_USER_ID=your_etsy_user_id
ETSY_SHOP_ID=your_etsy_shop_id
ETSY_SHOP_NAME=your_etsy_shop_name
